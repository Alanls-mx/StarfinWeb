generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum LicenseStatus {
  active
  suspended
}

enum UserRole {
  user
  admin
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(user)
  verified     Boolean   @default(false)
  banned       Boolean   @default(false)
  plan         String    @default("Free") // "Free", "Premium"
  planExpiresAt DateTime?
  createdAt    DateTime  @default(now())
  licenses     License[]
  reviews      Review[]
  orders       Order[]
  notifications Notification[]
  tickets      Ticket[]
  verificationTokens VerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

model Ticket {
  id          String         @id @default(cuid())
  subject     String
  status      String         @default("open") // "open", "answered", "closed"
  priority    String         @default("medium") // "low", "medium", "high"
  category    String         @default("general")
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    TicketMessage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model DocArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String
  category    String   @default("Geral")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model License {
  id         String        @id @default(cuid())
  licenseKey String        @unique
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  hwid       String?       // Global HWID (optional if using per-plugin HWID)
  plan       String
  status     LicenseStatus @default(active)
  expiresAt  DateTime?
  productIps Json?         // { pluginId: ["ip1", "ip2"] }
  createdAt  DateTime      @default(now())
  plugins    LicensePlugin[]
  logs       Log[]

  @@index([userId])
}

model Plugin {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  description   String
  price         Int             // Cents
  category      String          @default("Gameplay")
  licenseName   String?         // Name used for license validation (StarfinLicense)
  jarUrl        String?         // URL for the .jar file
  dependencies  Json?           // ["plugin1", "plugin2"]
  platform      String?         // "Bukkit", "Bungee", "Velocity"
  latestVersion String?
  licensePolicy Json?           // { type: "infinite" | "duration" | "date", months?: number, expiresAt?: string }
  imageUrl      String?
  images        Json?           // ["url1", "url2"]
  featured      Boolean         @default(false)
  createdAt     DateTime        @default(now())
  licenses      LicensePlugin[]
  reviews       Review[]
  orderItems    OrderItem[]

  @@index([createdAt])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    // "percentage" | "fixed"
  discountValue Int       // percentage or cents
  minPurchase   Int?      // cents
  expiresAt     DateTime?
  maxUses       Int?
  usedCount     Int       @default(0)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  orders        Order[]
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  totalCents    Int
  discountCents Int         @default(0)
  finalCents    Int
  status        String      @default("pending") // "pending", "completed", "cancelled"
  couponId      String?     
  coupon        Coupon?     @relation(fields: [couponId], references: [id])
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pluginId  String
  plugin    Plugin @relation(fields: [pluginId], references: [id])
  priceCents Int

  @@index([orderId])
  @@index([pluginId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1 to 5
  comment   String
  featured  Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pluginId  String
  plugin    Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, pluginId])
  @@index([pluginId])
  @@index([featured])
}

model LicensePlugin {
  id        String  @id @default(cuid())
  licenseId String
  pluginId  String
  hwid      String? // HWID bound specifically for this user/plugin combo
  license   License @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  plugin    Plugin  @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([licenseId, pluginId])
  @@index([pluginId])
}

model Log {
  id         String   @id @default(cuid())
  licenseId  String
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  serverIp   String
  serverPort Int
  serverName String
  platform   String
  pluginCore String?
  coreVersion String?
  performance Json
  createdAt  DateTime @default(now())

  @@index([licenseId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  userId    String?  // If null, it's global
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
